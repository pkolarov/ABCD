{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "DDS trust-graph activity — derived from `dds_audit_entries_total{action}` partitioned by the action vocabulary that ships in observability-plan.md Phase A, plus the FIDO2-tier Phase C catalog metrics (`dds_fido2_assertions_total{result}`, `dds_fido2_attestation_verify_total{result, fmt}`, `dds_sessions_issued_total{via}`). Each audit-action row pairs the success and *.rejected series so an operator can see the ratio at a glance; the three FIDO2 panels at the bottom partition the assertion / attestation / session-mint outcomes by their respective result labels.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["dds"],
      "targetBlank": false,
      "title": "DDS Overview",
      "tooltip": "Fleet overview dashboard",
      "type": "link",
      "url": "/d/dds-overview"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Attestation ingest activity. `attest` = accepted; `attest.rejected` = refused (bad signature, missing publisher capability, replay window, etc. — see observability-plan.md §4.A).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "attest.rejected" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by(action) (rate(dds_audit_entries_total{action=~\"attest|attest\\\\.rejected\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "title": "Attestations (accepted vs rejected)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Vouch ingest activity.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
