<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="DDS Test Package"
           Manufacturer="DDS E2E Tests"
           Version="1.0.0.0"
           UpgradeCode="B7A1C3D5-E6F7-4A8B-9C0D-1E2F3A4B5C6D"
           ProductCode="D1E2F3A4-B5C6-4D7E-8F9A-0B1C2D3E4F5A"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="DDS Test Package" Level="1">
      <ComponentGroupRef Id="TestFiles" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="DDS-Test" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="TestFiles" Directory="INSTALLFOLDER">
      <Component Id="ReadmeFile" Guid="A1B2C3D4-E5F6-4A7B-8C9D-0E1F2A3B4C5D">
        <File Id="Readme" Source="readme.txt" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
