<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>DDS.PolicyAgent</RootNamespace>
    <!-- Runs as a Windows Service when deployed; as a console app in dev. -->
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DdsPolicyAgent.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="8.0.1" />
    <!-- H-2 (security review): pure-managed Ed25519 verifier for
         signed policy/software envelopes. BouncyCastle avoids a
         native libsodium dependency which would complicate the
         MSI footprint. -->
    <PackageReference Include="BouncyCastle.Cryptography" Version="2.4.0" />
    <!-- L-16 (security review): explicit ACL on applied-state.json.
         Windows-only; no-op on other platforms. -->
    <PackageReference Include="System.IO.FileSystem.AccessControl" Version="5.0.0" Condition="'$(TargetFramework)' == 'net8.0' OR '$(TargetFramework)' == 'net9.0'" />
  </ItemGroup>

</Project>
