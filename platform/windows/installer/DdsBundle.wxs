<?xml version="1.0" encoding="UTF-8"?>
<!--
  DDS Windows Platform — WiX v4 MSI Bundle
  Installs:
    1. dds-node.exe          (Rust, Windows Service)
    2. DDS Auth Bridge        (C++, Windows Service)
    3. DDS Credential Provider (C++, COM DLL)
    4. DdsPolicyAgent         (.NET, Windows Service)
    5. DDS Tray Agent          (C++, optional)
    6. Configuration files

  Build variables (passed via -d on wix command line):
    BuildDir   — path to staged binaries for the target platform
    ConfigDir  — path to configuration templates
    Platform   — "x64" or "arm64"
    Version    — e.g. "1.0.0.0"
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- ============================================================ -->
  <!-- Platform detection: set InstallerPlatform to "x64" or "arm64" -->
  <!-- and pick the correct ProgramFiles folder                      -->
  <!-- ============================================================ -->
  <?ifdef Platform ?>
    <?if $(var.Platform) = "arm64" ?>
      <?define InstallerPlatform = "arm64" ?>
      <?define ProductName = "DDS Windows Platform (ARM64)" ?>
    <?else ?>
      <?define InstallerPlatform = "x64" ?>
      <?define ProductName = "DDS Windows Platform (x64)" ?>
    <?endif ?>
  <?else ?>
    <?define InstallerPlatform = "x64" ?>
    <?define ProductName = "DDS Windows Platform (x64)" ?>
  <?endif ?>

  <?ifndef Version ?>
    <?define Version = "1.0.0.0" ?>
  <?endif ?>

  <Package Name="$(var.ProductName)"
           Manufacturer="DDS"
           Version="$(var.Version)"
           UpgradeCode="F1A2B3C4-D5E6-7890-ABCD-123456789012"
           Compressed="yes"
           InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="A newer version of DDS is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- ============================================================ -->
    <!-- Install directory layout                                     -->
    <!-- ============================================================ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="DDS">
        <Directory Id="DIR_BIN" Name="bin" />
        <Directory Id="DIR_CONFIG" Name="config" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="System64Folder" />

    <!-- %ProgramData%\DDS\ for vault, logs, applied-state -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DIR_APPDATA_DDS" Name="DDS" />
    </StandardDirectory>

    <!-- ============================================================ -->
    <!-- Feature: Core (dds-node)                                     -->
    <!-- ============================================================ -->
    <Feature Id="F_Core" Title="DDS Node" Description="Core P2P directory service daemon" Level="1">
      <ComponentGroupRef Id="CG_DdsNode" />
      <ComponentGroupRef Id="CG_AppData" />
    </Feature>

    <!-- ============================================================ -->
    <!-- Feature: Auth Bridge (C++ service + CTAP2 engine)            -->
    <!-- ============================================================ -->
    <Feature Id="F_AuthBridge" Title="DDS Auth Bridge" Description="FIDO2 authentication bridge for Windows logon" Level="1">
      <ComponentGroupRef Id="CG_AuthBridge" />
    </Feature>

    <!-- ============================================================ -->
    <!-- Feature: Credential Provider (COM DLL)                       -->
    <!-- ============================================================ -->
    <Feature Id="F_CredProv" Title="DDS Credential Provider" Description="Windows logon credential provider" Level="1">
      <ComponentGroupRef Id="CG_CredProv" />
    </Feature>

    <!-- ============================================================ -->
    <!-- Feature: Policy Agent (.NET service)                         -->
    <!-- ============================================================ -->
    <Feature Id="F_PolicyAgent" Title="DDS Policy Agent" Description="Windows policy enforcement agent" Level="1">
      <ComponentGroupRef Id="CG_PolicyAgent" />
    </Feature>

    <!-- ============================================================ -->
    <!-- Feature: Tray Agent (optional, C++)                          -->
    <!-- ============================================================ -->
    <Feature Id="F_TrayAgent" Title="DDS Tray Agent" Description="System tray notification agent" Level="2">
      <ComponentGroupRef Id="CG_TrayAgent" />
    </Feature>

    <!-- ============================================================ -->
    <!-- Component: dds-node.exe                                      -->
    <!-- ============================================================ -->
    <ComponentGroup Id="CG_DdsNode" Directory="DIR_BIN">
      <Component Id="C_DdsNode" Guid="11111111-1111-1111-1111-111111111111">
        <File Id="dds_node_exe" Source="$(var.BuildDir)\dds-node.exe" KeyPath="yes" />
        <ServiceInstall Id="SI_DdsNode"
                        Name="DdsNode"
                        DisplayName="DDS Node"
                        Description="DDS distributed directory service"
                        Type="ownProcess"
                        Start="auto"
                        Account="LocalSystem"
                        ErrorControl="normal"
                        Arguments="run --config &quot;[DIR_CONFIG]node.toml&quot;" />
        <!-- Do NOT Start="install": the shipped node.toml is an unprovisioned
             template (no org_hash / domain) and dds-node refuses to load it
             with TOML parse error "missing field `org_hash`", causing MSI
             error 1920 + rollback. The service is registered with Start="auto"
             above so it comes up on next boot; the documented post-install
             workflow is `dds-node provision <bundle.dds>` which writes a real
             config and starts the service. -->
        <ServiceControl Id="SC_DdsNode"
                        Name="DdsNode"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
      <Component Id="C_DdsNodeConfig" Guid="22222222-2222-2222-2222-222222222222" Directory="DIR_CONFIG">
        <File Id="node_config_toml" Source="$(var.ConfigDir)\node.toml" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ============================================================ -->
    <!-- Component: DDS Auth Bridge service                           -->
    <!-- ============================================================ -->
    <ComponentGroup Id="CG_AuthBridge" Directory="DIR_BIN">
      <Component Id="C_AuthBridge" Guid="33333333-3333-3333-3333-333333333333">
        <File Id="auth_bridge_exe" Source="$(var.BuildDir)\DdsAuthBridge.exe" KeyPath="yes" />
        <ServiceInstall Id="SI_AuthBridge"
                        Name="DdsAuthBridge"
                        DisplayName="DDS Auth Bridge"
                        Description="DDS FIDO2 authentication bridge for Windows logon"
                        Type="ownProcess"
                        Start="auto"
                        Account="LocalSystem"
                        ErrorControl="normal">
          <ServiceDependency Id="DdsNode" />
        </ServiceInstall>
        <!-- See SC_DdsNode: deferred to first boot / post-provision. -->
        <ServiceControl Id="SC_AuthBridge"
                        Name="DdsAuthBridge"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />

        <!-- **H-6 step-2 (security review)**: tell the Auth Bridge
             where to find the per-install HMAC secret generated below
             by CA_GenHmacSecret. -->
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\DDS\AuthBridge"
                       Name="HmacSecretPath"
                       Value="[CommonAppDataFolder]DDS\node-hmac.key"
                       Type="expandable" />

        <!-- **A-2 (security review)**: select the named-pipe transport
             added in H-7 step-2b by default. The Rust dds-node.toml
             template installed alongside this MSI declares
             `api_addr = "pipe:dds-api"`, so the Auth Bridge has to
             dial the same pipe rather than the loopback TCP listener
             (which the hardened config disables). Operators who want
             to keep the legacy TCP path can remove this value or set
             it to "http://127.0.0.1:5551" via group policy. -->
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\DDS\AuthBridge"
                       Name="ApiAddr"
                       Value="pipe:dds-api"
                       Type="string" />
      </Component>
    </ComponentGroup>

    <!-- ============================================================ -->
    <!-- Threat-model §3 / open item #8: Custom action — apply a       -->
    <!-- restrictive DACL to %ProgramData%\DDS so subsequently created -->
    <!-- vault / HMAC secret / applied-state / log files inherit       -->
    <!-- LocalSystem + BUILTIN\Administrators only. Without this,      -->
    <!-- %ProgramData%\DDS inherits BUILTIN\Users:Read from its parent -->
    <!-- on most Windows SKUs and CA_GenHmacSecret would write the     -->
    <!-- per-install HMAC secret into a world-readable directory.      -->
    <!--                                                                -->
    <!-- Defense-in-depth: the C++ Auth Bridge also self-heals this    -->
    <!-- DACL on every service start (FileLog::Init), and the .NET     -->
    <!-- Policy Agent applies the same DACL to the staging cache and   -->
    <!-- to applied-state.json (B-6 / L-16). The MSI custom action     -->
    <!-- closes the install-time race so even files written *before*   -->
    <!-- those services first start are protected.                     -->
    <!-- ============================================================ -->
    <CustomAction Id="CA_RestrictDataDirAcl"
                  FileRef="dds_node_exe"
                  ExeCommand='restrict-data-dir-acl --data-dir "[CommonAppDataFolder]DDS"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- ============================================================ -->
    <!-- H-6 step-2: Custom action — generate the per-install HMAC    -->
    <!-- secret on first install. Runs `dds-node.exe gen-hmac-secret` -->
    <!-- which writes 32 random bytes at the target path unless a     -->
    <!-- file already exists (so reinstalls / repairs do not rotate   -->
    <!-- the secret and desynchronise the Auth Bridge from the node). -->
    <!-- Deferred execution + Impersonate="no" => runs as LocalSystem,-->
    <!-- matching the service accounts that will read the file later. -->
    <!-- ============================================================ -->
    <CustomAction Id="CA_GenHmacSecret"
                  FileRef="dds_node_exe"
                  ExeCommand='gen-hmac-secret --keep-existing --out "[CommonAppDataFolder]DDS\node-hmac.key"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- ============================================================ -->
    <!-- SC-3-W (security review 2026-04-28): Custom action — stamp   -->
    <!-- the node Ed25519 pubkey into the Policy Agent's              -->
    <!-- appsettings.json before the DdsPolicyAgent service first     -->
    <!-- starts. The agent's Program.cs fails closed on an empty      -->
    <!-- PinnedNodePubkeyB64, so without this stamp the SCM auto-     -->
    <!-- start would crash-loop on every fresh MSI install until an   -->
    <!-- operator either ran single-file `dds-node provision` or      -->
    <!-- hand-edited the JSON. Runs `dds-node.exe stamp-agent-pubkey` -->
    <!-- which loads (or creates, on first install) %ProgramData%\DDS-->
    <!-- \node_key.bin, derives the base64 pubkey, and rewrites the   -->
    <!-- DdsPolicyAgent.PinnedNodePubkeyB64 field in place — every    -->
    <!-- other appsettings key (Logging, NodeBaseUrl, StateDir, the   -->
    <!-- empty DeviceUrn placeholder) is preserved. DeviceUrn cannot  -->
    <!-- be stamped here: it is only known after enrollment with a    -->
    <!-- domain, which is *not* part of the MSI install path —        -->
    <!-- operators run `dds-bootstrap-domain` (or single-file         -->
    <!-- provisioning) post-install to populate it.                   -->
    <!--                                                                -->
    <!-- Deferred + Impersonate="no" so the action runs as LocalSystem-->
    <!-- and the freshly-created node_key.bin inherits the protected  -->
    <!-- DACL applied above by CA_RestrictDataDirAcl.                 -->
    <!-- ============================================================ -->
    <CustomAction Id="CA_StampAgentPubkey"
                  FileRef="dds_node_exe"
                  ExeCommand='stamp-agent-pubkey --data-dir "[CommonAppDataFolder]DDS" --config-dir "[INSTALLFOLDER]config"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <InstallExecuteSequence>
      <!-- Run after the files are laid down (so dds-node.exe exists)
           and the data dir is created (so we have something to ACL),
           but before CA_GenHmacSecret so node-hmac.key is created
           underneath the already-restricted DACL — it would otherwise
           inherit the wide-open %ProgramData% ACL at write time and
           keep that ACL even after we tighten the parent. -->
      <Custom Action="CA_RestrictDataDirAcl" After="InstallFiles" Condition="NOT REMOVE" />
      <!-- Run after the files are laid down (so dds-node.exe exists)
           and the service accounts are created (so the directory is
           writable), but before the services start (so dds-node and
           the Auth Bridge both see the same secret on first boot). -->
      <Custom Action="CA_GenHmacSecret" After="CA_RestrictDataDirAcl" Condition="NOT REMOVE" />
      <!-- SC-3-W: stamp the agent pubkey after node_key.bin can be
           written under the restricted DACL but before service start
           so the DdsPolicyAgent service finds the pinning field
           populated on its first run. Sequence after CA_GenHmacSecret
           so a single re-entrant deferred phase covers all three
           helpers. -->
      <Custom Action="CA_StampAgentPubkey" After="CA_GenHmacSecret" Condition="NOT REMOVE" />
    </InstallExecuteSequence>

    <!-- ============================================================ -->
    <!-- Component: DDS Credential Provider DLL                       -->
    <!-- ============================================================ -->
    <!-- ICE09 warns about non-permanent System32 component; this is intentional
         for credential providers — they must live in System32 for logonui.exe -->
    <ComponentGroup Id="CG_CredProv" Directory="System64Folder">
      <Component Id="C_CredProvDll" Guid="44444444-4444-4444-4444-444444444444" Permanent="yes">
        <File Id="credprov_dll" Source="$(var.BuildDir)\DdsCredentialProvider.dll" KeyPath="yes" />

        <!-- COM registration: HKCR\CLSID\{...}\InprocServer32 -->
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\Classes\CLSID\{a7f3b2c1-9d4e-4f8a-b6c5-2e1d0a3f7b9c}"
                       Value="DDS Credential Provider"
                       Type="string" />
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\Classes\CLSID\{a7f3b2c1-9d4e-4f8a-b6c5-2e1d0a3f7b9c}\InprocServer32"
                       Value="[System64Folder]DdsCredentialProvider.dll"
                       Type="expandable" />
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\Classes\CLSID\{a7f3b2c1-9d4e-4f8a-b6c5-2e1d0a3f7b9c}\InprocServer32"
                       Name="ThreadingModel"
                       Value="Apartment"
                       Type="string" />

        <!-- Credential Provider registration -->
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Authentication\Credential Providers\{a7f3b2c1-9d4e-4f8a-b6c5-2e1d0a3f7b9c}"
                       Value="DdsCredentialProvider"
                       Type="string" />
      </Component>
    </ComponentGroup>

    <!-- ============================================================ -->
    <!-- Component: DDS Policy Agent (.NET)                           -->
    <!-- ============================================================ -->
    <ComponentGroup Id="CG_PolicyAgent" Directory="DIR_BIN">
      <Component Id="C_PolicyAgent" Guid="55555555-5555-5555-5555-555555555555">
        <File Id="policy_agent_exe" Source="$(var.BuildDir)\DdsPolicyAgent.exe" KeyPath="yes" />
        <ServiceInstall Id="SI_PolicyAgent"
                        Name="DdsPolicyAgent"
                        DisplayName="DDS Policy Agent"
                        Description="DDS Windows policy enforcement agent"
                        Type="ownProcess"
                        Start="auto"
                        Account="LocalSystem"
                        ErrorControl="normal"
                        Arguments="--contentRoot &quot;[INSTALLFOLDER]&quot;">
          <ServiceDependency Id="DdsNode" />
        </ServiceInstall>
        <!-- See SC_DdsNode: deferred to first boot / post-provision. -->
        <ServiceControl Id="SC_PolicyAgent"
                        Name="DdsPolicyAgent"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
      <Component Id="C_PolicyAgentConfig" Guid="88888888-8888-8888-8888-888888888888" Directory="DIR_CONFIG">
        <File Id="policy_agent_appsettings" Source="$(var.ConfigDir)\appsettings.json" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ============================================================ -->
    <!-- Component: DDS Tray Agent (optional)                         -->
    <!-- ============================================================ -->
    <ComponentGroup Id="CG_TrayAgent" Directory="DIR_BIN">
      <Component Id="C_TrayAgent" Guid="77777777-7777-7777-7777-777777777777">
        <File Id="tray_agent_exe" Source="$(var.BuildDir)\DdsTrayAgent.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ============================================================ -->
    <!-- Component: ProgramData directory for vault + state           -->
    <!-- ============================================================ -->
    <ComponentGroup Id="CG_AppData" Directory="DIR_APPDATA_DDS">
      <Component Id="C_AppDataDir" Guid="66666666-6666-6666-6666-666666666666">
        <CreateFolder />
      </Component>
    </ComponentGroup>

  </Package>
</Wix>
