<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.dds.node</string>
  <!--
    ProgramArguments points at a wrapper that:
      1. tries to unseal DDS_NODE_PASSPHRASE from the System Keychain
         (silent fall-through if no sealed passphrase is configured),
      2. exports it,
      3. exec's `dds-node run <config>`.
    See platform/macos/packaging/SEALED-PASSPHRASE.md.
  -->
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/sbin/dds-launchd-wrapper</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Library/Application Support/DDS</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>Disabled</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/var/log/dds/dds-node.out</string>
  <key>StandardErrorPath</key>
  <string>/var/log/dds/dds-node.err</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>RUST_LOG</key>
    <string>info</string>
  </dict>
</dict>
</plist>
